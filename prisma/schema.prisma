model Payroll {
  ID                  Int             @id @default(autoincrement())
  empPostRankLinkId   Int
  postId              Int
  attendanceId        Int
  // taxDeductionPostRankLinkId Int?         @default(0)
  month               Int
  year                Int
  workingDays         Int
  basicSalary         Decimal?        @db.Decimal(10, 2)
  fourHourPay         Decimal?        @db.Decimal(10, 2)
  eightHourPay        Decimal?        @db.Decimal(10, 2)
  bonus               Decimal?        @db.Decimal(10, 2)
  weeklyOff           Decimal?        @db.Decimal(10, 2)
  hra                 Decimal?        @db.Decimal(10, 2)
  conveyance          Decimal?        @db.Decimal(10, 2)
  kitWashingAllowance Decimal?        @db.Decimal(10, 2)
  uniformAllowance    Decimal?        @db.Decimal(10, 2)
  cityAllowance       Decimal?        @db.Decimal(10, 2)
  vda                 Decimal?        @db.Decimal(10, 2)
  otherAllowance      Decimal?        @db.Decimal(10, 2)
  specialAllowance    Decimal?        @db.Decimal(10, 2) // Newly added @19.03.25
  grossPay            Decimal?        @db.Decimal(10, 2)
  extraDuty           Decimal?        @db.Decimal(10, 2)
  advance             Decimal?        @db.Decimal(10, 2)
  esi                 Decimal?        @db.Decimal(10, 2)
  epf                 Decimal?        @db.Decimal(10, 2)
  beltDeduction       Decimal?        @db.Decimal(10, 2)
  bootDeduction       Decimal?        @db.Decimal(10, 2)
  uniformDeduction    Decimal?        @db.Decimal(10, 2)
  otherDeduction      Decimal?        @db.Decimal(10, 2)
  totalDeduction      Decimal?        @db.Decimal(10, 2)
  pTax                Decimal?        @db.Decimal(10, 2)
  netPay              Decimal?        @db.Decimal(10, 2)
  empEsiTaxPercent    Decimal?        @db.Decimal(10, 2)
  empEpfTaxPercent    Decimal?        @db.Decimal(10, 2)
  emplrEsiTaxPercent  Decimal?        @db.Decimal(10, 2)
  emplrEpfTaxPercent  Decimal?        @db.Decimal(10, 2)
  createdAt           DateTime?       @default(now()) @db.DateTime(0)
  updatedAt           DateTime?       @default(now()) @db.DateTime(0)
  EmpPostRankLink     EmpPostRankLink @relation(fields: [empPostRankLinkId], references: [ID], onDelete: NoAction, onUpdate: NoAction)
  Attendance          Attendance      @relation(fields: [attendanceId], references: [ID], onDelete: NoAction, onUpdate: NoAction)
  // TaxDeductionPostRankLink   TaxDeductionPostRankLink? @relation(fields: [taxDeductionPostRankLinkId], references: [ID], onDelete: NoAction, onUpdate: NoAction)

  @@index([empPostRankLinkId], map: "empPostRankLinkId")
  @@index([attendanceId], map: "attendanceId")
  // @@index([taxDeductionPostRankLinkId], map: "taxDeductionPostRankLinkId")
  @@index([postId], map: "postId")
  @@map("payroll")
}

model Invoice {
  ID                 Int                @id @default(autoincrement())
  invoiceNumber      String             @unique(map: "invoiceNumber") @db.VarChar(32)
  postId             Int
  month              Int
  year               Int
  invoiceDate        DateTime           @db.Date
  attendanceMode     InvoiceAttendanceMode
  gstRate            Decimal            @default(18.00) @db.Decimal(5, 2)
  taxableValue       Decimal            @db.Decimal(12, 2)
  gstAmount          Decimal            @db.Decimal(12, 2)
  totalAmount        Decimal            @db.Decimal(12, 2)
  status             InvoiceStatus      @default(GENERATED)
  sellerName         String             @db.VarChar(255)
  sellerAddress      String?            @db.Text
  sellerGstin        String?            @db.VarChar(15)
  sellerPan          String?            @db.VarChar(15)
  buyerName          String             @db.VarChar(255)
  buyerAddress       String?            @db.Text
  buyerGstin         String?            @db.VarChar(15)
  buyerPan           String?            @db.VarChar(15)
  createdAt          DateTime?          @default(now()) @db.DateTime(0)
  updatedAt          DateTime?          @default(now()) @db.DateTime(0)
  Post               Post               @relation(fields: [postId], references: [ID], onDelete: NoAction, onUpdate: NoAction)
  InvoiceItem        InvoiceItem[]

  @@index([postId], map: "postId")
  @@index([month, year], map: "monthYear")
  @@unique([postId, month, year], map: "postMonthYear")
  @@map("invoice")
}

model InvoiceItem {
  ID              Int       @id @default(autoincrement())
  invoiceId       Int
  employeeId      Int
  employeeName    String    @db.VarChar(255)
  employeeCode    String?   @db.VarChar(50)
  designation     String?   @db.VarChar(255)
  attendanceDays  Decimal?  @db.Decimal(8, 2)
  billedNetAmount Decimal   @db.Decimal(12, 2)
  createdAt       DateTime? @default(now()) @db.DateTime(0)
  updatedAt       DateTime? @default(now()) @db.DateTime(0)
  Invoice         Invoice   @relation(fields: [invoiceId], references: [ID], onDelete: Cascade, onUpdate: NoAction)

  @@index([invoiceId], map: "invoiceId")
  @@index([employeeId], map: "employeeId")
  @@map("invoiceitem")
}

enum InvoiceAttendanceMode {
  DERIVE_ATTENDANCE @map("Derive Attendance")
  FULL_ATTENDANCE   @map("Full Attendance")
}

enum InvoiceStatus {
  DRAFT
  GENERATED
  CANCELLED
  PAID
}

enum ReportName {
  NONE                     @map("None")
  VIEW_DS_REPORT           @map("View DS Report")
  ESI_REPORT               @map("ESI Report")
  EPF_REPORT               @map("EPF Report")
  PTAX_REPORT              @map("PTax Report")
  WITHOUT_ALLOWANCE_REPORT @map("Without Allowance Report")
  NEW_PAYROLL_REPORT       @map("New Payroll Report")
  DSL_REPORT               @map("DSL Report")
  LNT_REPORT               @map("LNT Report")
  OTHERS_REPORT            @map("Others Report")
  SALARY_REPORT            @map("Salary Report")
}

model Post {
  ID              Int            @id @default(autoincrement())
  postName        String         @unique(map: "postName") @db.VarChar(255)
  address         String         @db.VarChar(255)
  gstin           String         @db.VarChar(15)
  pan             String         @db.VarChar(15)
  contactPerson   String?        @db.VarChar(255)
  status          status
  serviceLocation String?        @db.VarChar(255) // TODO: Remove later as not needed
  contractDate    DateTime?      @db.Date
  phoneNum        String?        @db.VarChar(20)
  docGst          String?        @db.Text
  docPan          String?        @db.Text
  docContract     String?        @db.Text
  docOther        String?        @db.Text
  createdAt       DateTime?      @default(now()) @db.DateTime(0)
  updatedAt       DateTime?      @default(now()) @db.DateTime(0)
  isDeleted       Boolean?       @default(false)
  reportName      ReportName?    @default(NONE)
  deletedAt       DateTime?      @db.DateTime(0)
  PostHistory     PostHistory[]
  PostRankLink    PostRankLink[]
  Invoice         Invoice[]

  @@map("post")
}

model PostHistory {
  ID               Int                @id @default(autoincrement())
  postId           Int
  postName         String             @unique(map: "postName") @db.VarChar(255)
  address          String             @db.VarChar(255)
  pan              String             @db.VarChar(15)
  gstin            String             @db.VarChar(15)
  docGst           String?            @db.VarChar(255)
  docPan           String?            @db.VarChar(255)
  wef              DateTime?          @db.Date
  wet              DateTime?          @db.Date
  reason           String?            @db.Text
  createdAt        DateTime?          @default(now()) @db.DateTime(0)
  Post             Post               @relation(fields: [postId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "posthistory_ibfk_1")
  PostHistRankLink PostHistRankLink[]

  @@index([postId], map: "postId")
  @@map("posthistory")
}

model PostHistRankLink {
  ID                  Int                   @id @default(autoincrement())
  postHistId          Int
  rankId              Int
  basicSalary         Decimal?              @db.Decimal(10, 2)
  kitWashingAllowance Decimal?              @db.Decimal(10, 2)
  cityAllowance       Decimal?              @db.Decimal(10, 2)
  conveyance          Decimal?              @db.Decimal(10, 2)
  hra                 Decimal?              @db.Decimal(10, 2)
  vda                 Decimal?              @db.Decimal(10, 2)
  uniformAllowance    Decimal?              @db.Decimal(10, 2)
  reason              String?               @db.Text
  createdAt           DateTime?             @default(now()) @db.DateTime(0)
  EmpPostHistRankLink EmpPostHistRankLink[]
  PostHistory         PostHistory           @relation(fields: [postHistId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "posthistranklink_ibfk_1")
  Rank                Rank                  @relation(fields: [rankId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "posthistranklink_ibfk_2")

  @@index([postHistId], map: "postHistId")
  @@index([rankId], map: "rankId")
  @@map("posthistranklink")
}

model PostRankLink {
  ID                       Int                        @id @default(autoincrement())
  postId                   Int
  rankId                   Int
  basicSalary              Decimal?                   @db.Decimal(10, 2)
  kitWashingAllowance      Decimal?                   @db.Decimal(10, 2)
  cityAllowance            Decimal?                   @db.Decimal(10, 2)
  conveyance               Decimal?                   @db.Decimal(10, 2)
  hra                      Decimal?                   @db.Decimal(10, 2)
  vda                      Decimal?                   @db.Decimal(10, 2)
  uniformAllowance         Decimal?                   @db.Decimal(10, 2)
  otherAllowance           Decimal?                   @db.Decimal(10, 2)
  weeklyOff                Decimal?                   @db.Decimal(10, 2) // Newly added @19.03.25
  specialAllowance         Decimal?                   @db.Decimal(10, 2) // Newly added @19.03.25
  taxDeducName             String?                    @db.VarChar(255)
  createdAt                DateTime?                  @default(now()) @db.DateTime(0)
  updatedAt                DateTime?                  @default(now()) @db.DateTime(0)
  Post                     Post                       @relation(fields: [postId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "postranklink_ibfk_1")
  Rank                     Rank                       @relation(fields: [rankId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "postranklink_ibfk_2")
  EmpPostRankLink          EmpPostRankLink[]
  TaxDeductionPostRankLink TaxDeductionPostRankLink[]

  @@index([postId], map: "postId")
  @@index([rankId], map: "rankId")
  @@map("postranklink")
}

model Rank {
  ID                  Int                @id @default(autoincrement())
  designation         String             @unique(map: "designation") @db.VarChar(255)
  basicSalary         Decimal            @db.Decimal(10, 2)
  kitWashingAllowance Decimal?           @db.Decimal(10, 2)
  cityAllowance       Decimal?           @db.Decimal(10, 2)
  conveyance          Decimal?           @db.Decimal(10, 2)
  hra                 Decimal?           @db.Decimal(10, 2)
  vda                 Decimal?           @db.Decimal(10, 2)
  uniformAllowance    Decimal?           @db.Decimal(10, 2)
  otherAllowance      Decimal?           @db.Decimal(10, 2)
  weeklyOff           Decimal?           @db.Decimal(10, 2) // Newly added @19.03.25
  specialAllowance    Decimal?           @db.Decimal(10, 2)
  createdAt           DateTime?          @default(now()) @db.DateTime(0)
  updatedAt           DateTime?          @default(now()) @db.DateTime(0)
  isDeleted           Boolean?           @default(false)
  deletedAt           DateTime?          @db.DateTime(0)
  PostHistRankLink    PostHistRankLink[]
