  @@map("rank")
}

model TaxesAndDeduction {
  ID                       Int                        @id @default(autoincrement())
  taxDeducName             String                     @unique(map: "taxDeducName") @db.VarChar(255)
  pTax                     Decimal                    @db.Decimal(10, 2)
  esi                      Decimal                    @db.Decimal(10, 2)
  epf                      Decimal                    @db.Decimal(10, 2)
  employerEpf              Decimal?                   @db.Decimal(10, 2)
  employerEsi              Decimal?                   @db.Decimal(10, 2)
  uniformDeduction         Decimal?                   @db.Decimal(10, 2)
  otherDeduction           Decimal?                   @db.Decimal(10, 2)
  createdAt                DateTime?                  @default(now()) @db.DateTime(0)
  TaxDeductionPostRankLink TaxDeductionPostRankLink[]

  @@map("taxesanddeduction")
}

model TaxDeductionPostRankLink {
  ID                Int               @id @default(autoincrement())
  taxDeductionID    Int
  postRankLinkId    Int
  createdAt         DateTime?         @default(now()) @db.DateTime(0)
  updatedAt         DateTime?         @default(now()) @db.DateTime(0)
  TaxesAndDeduction TaxesAndDeduction @relation(fields: [taxDeductionID], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "taxdeductionpostranklink_ibfk_1")
  PostRankLink      PostRankLink      @relation(fields: [postRankLinkId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "taxdeductionpostranklink_ibfk_2")
  // Payroll           Payroll[]

  @@index([taxDeductionID], map: "taxDeductionID")
  @@index([postRankLinkId], map: "postRankLinkId")
  @@map("taxdeductionpostranklink")
}

model TokenBlacklist {
  ID        Int       @id @default(autoincrement())
  token     String?   @db.Text
  createdAt DateTime? @default(now()) @db.DateTime(0)

  @@map("tokenblacklist")
}

model User {
  ID           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  username     String    @unique(map: "username") @db.VarChar(255)
  email        String?   @unique(map: "email") @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  role         userRole
  userVerified Boolean?  @default(false)
  profilePhoto String?   @db.VarChar(255)
  status       status
  createdAt    DateTime? @default(now()) @db.DateTime(0)
  updatedAt    DateTime? @default(now()) @db.DateTime(0)

  @@map("user")
}

enum userRole {
  Admin
  Manager
  User
  DevAdmin
}

enum status {
  Active
  Inactive
  Deleted
}

enum empStatus {
  Active
  Transferred
  Discharged
  Absconded
  Resigned
  Inactive
  Deleted
}
