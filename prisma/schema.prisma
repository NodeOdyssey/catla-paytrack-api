generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Attendance {
  ID                Int             @id @default(autoincrement())
  empPostRankLinkId Int
  month             Int
  year              Int
  daysPresent       Int
  daysAbsent        Int
  extraDutyFourHr   Int?
  extraDutyEightHr  Int?
  docAttendance     String?         @db.Text
  createdAt         DateTime?       @default(now()) @db.DateTime(0)
  updatedAt         DateTime?       @default(now()) @db.DateTime(0)
  EmpPostRankLink   EmpPostRankLink @relation(fields: [empPostRankLinkId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "attendance_ibfk_1")
  Payroll           Payroll[]

  @@index([empPostRankLinkId], map: "empPostRankLinkId")
  @@map("attendance")
}

model Employee {
  ID                  Int                   @id @default(autoincrement())
  empId               String?               @db.VarChar(50)
  empName             String                @db.VarChar(255)
  fatherName          String                @db.VarChar(255)
  motherName          String?               @db.VarChar(255)
  gender              String                @db.VarChar(10)
  dob                 DateTime              @db.Date
  phoneNum            String                @db.VarChar(15)
  altPhoneNum         String?               @db.VarChar(15)
  villTown            String                @db.VarChar(100)
  postOffice          String                @db.VarChar(100)
  policeStation       String                @db.VarChar(100)
  district            String                @db.VarChar(100)
  pinCode             String                @db.VarChar(10)
  state               String                @db.VarChar(100)
  qualification       String                @db.VarChar(100)
  height              Decimal?              @db.Decimal(5, 2) // TODO: Check why (3,2) is not working
  bloodGroup          String?               @db.VarChar(5)
  idMark              String?               @db.VarChar(255)
  bankName            String                @db.VarChar(100)
  accNum              String?               @db.VarChar(20)
  epfNo               String?               @db.VarChar(30)
  esiNo               String?               @db.VarChar(30)
  pan                 String?               @db.VarChar(10)
  aadhaarNo           String?               @db.VarChar(14)
  ifsc                String                @db.VarChar(11)
  docContract         String?               @db.Text
  docResume           String?               @db.Text
  docPan              String?               @db.Text
  docOther            String?               @db.Text
  docAadhaar          String?               @db.Text
  profilePhoto        String?               @db.Text
  dateOfJoining       DateTime?             @db.Date
  dateOfRejoining     DateTime?             @db.Date
  dateOfAbsconding    DateTime?             @db.Date
  dateOfResignation   DateTime?             @db.Date
  dateOfDischarge     DateTime?             @db.Date
  idCardName          String?               @db.VarChar(255)
  idCardIssued        Boolean?              @default(false)
  idCardIssueDate     DateTime?             @db.Date
  idCardExpiryDate    DateTime?             @db.Date
  remarks             String?               @db.Text
  salaryAdvance       Decimal?              @default(0) @db.Decimal(10, 2)
  noOfAdvancePayments Int?                  @default(0)
  advanceDetails      Json?
  empStatus           empStatus?
  isDeleted           Boolean?              @default(false)
  CreatedAt           DateTime?             @default(now()) @db.DateTime(0)
  UpdatedAt           DateTime?             @default(now()) @db.DateTime(0)
  DeletedAt           DateTime?             @db.DateTime(0)
  EmployeeHistory     EmployeeHistory[]
  EmpPostHistRankLink EmpPostHistRankLink[]
  EmpPostRankLink     EmpPostRankLink[]

  @@map("employee")
}

model EmployeeHistory {
  ID            Int       @id @default(autoincrement())
  empId         String    @db.VarChar(10)
  empTableId    Int
  empName       String    @db.VarChar(255)
  fatherName    String    @db.VarChar(255)
  dob           DateTime  @db.Date
  gender        String    @db.VarChar(10)
  height        Decimal?  @db.Decimal(3, 2)
  idMark        String?   @db.VarChar(255)
  profilePhoto  String?   @db.VarChar(255)
  qualification String    @db.VarChar(100)
  bloodGroup    String?   @db.VarChar(5)
  applyDate     DateTime? @db.Date
  villTown      String    @db.VarChar(100)
  postOffice    String    @db.VarChar(100)
  policeStation String    @db.VarChar(100)
  district      String    @db.VarChar(100)
  pinCode       String    @db.VarChar(10)
  state         String    @db.VarChar(100)
  phoneNum      String    @db.VarChar(15)
  altPhoneNum   String?   @db.VarChar(15)
  bankName      String    @db.VarChar(100)
  accNum        String    @db.VarChar(20)
  ifsc          String    @db.VarChar(11)
  pan           String    @db.VarChar(10)
  aadhaarNo     String    @db.VarChar(14)
  docPan        String?   @db.VarChar(100)
  docAadhaar    String?   @db.VarChar(100)
  docAddProof   String?   @db.VarChar(100)
  esiNo         String?   @db.VarChar(20)
  uan           String?   @db.VarChar(15)
  epfNo         String?   @db.VarChar(15)
  dateOfJoining DateTime? @db.Date
  CreatedAt     DateTime? @default(now()) @db.DateTime(0)
  Reason        String?   @db.Text
  // Employee      Employee  @relation(fields: [empTableId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "employeehistory_ibfk_1")
  Employee      Employee  @relation(fields: [empTableId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "employeehistory_ibfk_unique")

  @@index([empTableId], map: "empTableId")
  @@map("employeehistory")
}

model EmpPostHistRankLink {
  ID                 Int              @id @default(autoincrement())
  empTableId         Int?
  PostHistRankLinkID Int
  DateOfPosting      DateTime         @db.Date
  TransferredFrom    String?          @db.VarChar(255)
  DateOfTransfer     DateTime?        @db.Date
  TransferredTo      String?          @db.VarChar(255)
  ReApplyDate        DateTime?        @db.Date
  DateOfRehire       DateTime?        @db.Date
  TC                 String?          @db.VarChar(255)
  DateOfDischarge    DateTime?        @db.Date
  Reason             String?          @db.Text
  CreatedAt          DateTime?        @default(now()) @db.DateTime(0)
  Employee           Employee?        @relation(fields: [empTableId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "empposthistranklink_ibfk_1")
  PostHistRankLink   PostHistRankLink @relation(fields: [PostHistRankLinkID], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "empposthistranklink_ibfk_2")

  @@index([empTableId], map: "empTableId")
  @@index([PostHistRankLinkID], map: "PostHistRankLinkID")
  @@map("empposthistranklink")
}

model EmpPostRankLink {
  ID                Int          @id @default(autoincrement())
  empTableId        Int
  postRankLinkId    Int
  dateOfPosting     DateTime     @db.Date
  status            empStatus    @default(Active)
  dateOfDischarge   DateTime?    @db.Date
  transferredFrom   String?      @db.VarChar(255)
  dateOfTransfer    DateTime?    @db.Date
  transferredTo     String?      @db.VarChar(255)
  promotedFrom      String?      @db.VarChar(255)
  dateOfPromotion   DateTime?    @db.Date
  promotedTo        String?      @db.VarChar(255)
  dateOfResignation DateTime?    @db.Date
  dateOfAbsconding  DateTime?    @db.Date
  dateOfRejoining   DateTime?    @db.Date
  // reApplyDate     DateTime?    @db.Date
  // dateOfRehire    DateTime?    @db.Date
  CreatedAt         DateTime?    @default(now()) @db.DateTime(0)
  UpdatedAt         DateTime?    @default(now()) @db.DateTime(0)
  Attendance        Attendance[]
  Employee          Employee     @relation(fields: [empTableId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "emppostranklink_ibfk_1")
  PostRankLink      PostRankLink @relation(fields: [postRankLinkId], references: [ID], onDelete: NoAction, onUpdate: NoAction, map: "emppostranklink_ibfk_2")
  Payroll           Payroll[]

  @@index([empTableId], map: "empTableID_idx") // renamed index
  @@index([postRankLinkId], map: "postRankLinkID_idx") // renamed index
  @@map("emppostranklink")
}

